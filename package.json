{
  "name": "chittyregistry-universal",
  "version": "2.0.0",
  "description": "ChittyRegistry Universal System - Cloudflare Workers",
  "main": "src/universal-registry-worker.js",
  "scripts": {
    "dev": "npx wrangler dev",
    "deploy": "npx wrangler deploy",
    "deploy:staging": "npx wrangler deploy --env staging",
    "deploy:production": "npx wrangler deploy --env production",
    "lint": "eslint . --ext .js,.ts --max-warnings 0",
